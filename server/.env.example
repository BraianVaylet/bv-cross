# Puerto HTTP
PORT=8787

# Ruta del archivo SQLite. En hosting con volumen persistente usá, por ejemplo: /data/bvcross.db
DB_PATH=./data/bvcross.db

# production en deploy
NODE_ENV=development

# Días de vida de la sesión
SESSION_DAYS=30

# Forzar cookie Secure (por defecto: true en production)
# COOKIE_SECURE=true

# Orígenes extra permitidos para mutaciones (CSV). Normalmente no hace falta.
# APP_ORIGINS=https://bvcross.tudominio.com

# Confiar en x-forwarded-* del proxy del hosting (por defecto: true en production)
# TRUST_PROXY=true
