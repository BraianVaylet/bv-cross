{
  "name": "bv-cross",
  "version": "1.0.0",
  "private": true,
  "description": "BV Cross — seguimiento de RMs y cálculo de cargas para CrossFit",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev:server": "pnpm --filter @bvcross/server dev",
    "dev:client": "pnpm --filter @bvcross/client dev",
    "build": "pnpm --filter @bvcross/client build && pnpm --filter @bvcross/server build",
    "start": "pnpm --filter @bvcross/server start",
    "typecheck": "pnpm --filter @bvcross/server typecheck && pnpm --filter @bvcross/client typecheck",
    "db:migrate": "pnpm --filter @bvcross/server db:migrate"
  }
}
